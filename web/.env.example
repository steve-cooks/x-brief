# Optional: override where the Next.js API route reads briefing JSON.
# No API keys or backend credentials are required.

X_BRIEF_DATA_DIR=../data

# Bearer token for the local OpenClaw gateway used by /api/scan to trigger scans.
OPENCLAW_GATEWAY_TOKEN=
# Command to trigger a scan (e.g. path to wrapper script that calls OpenClaw cron)
XBRIEF_SCAN_COMMAND=
# OpenClaw cron job ID for the scan task
XBRIEF_CRON_JOB_ID=
